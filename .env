COMPOSE_PROJECT_NAME=clothing-search

# Postgres
POSTGRES_DB=shopdb
POSTGRES_USER=shopuser
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Milvus
MILVUS_PORT=19530

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=product-images

# Go 
GO_PORT=8080
GRPC_ML_SERVICE_ADDR=ml-service:50051
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=disable
MINIO_ENDPOINT=minio:${MINIO_PORT}
MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}

# Python
PYTHON_PORT=50051  
ML_MODEL_NAME=resnet50